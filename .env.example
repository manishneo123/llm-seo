# LLM API keys (required for monitor + content agents; OPENAI also used for brief image generation)
OPENAI_API_KEY=
# Optional: OpenAI chat model (default: gpt-5.4). For citations, set OPENAI_USE_WEB_SEARCH=1 and optionally OPENAI_SEARCH_MODEL.
# OPENAI_MODEL=gpt-5.4
# OPENAI_USE_WEB_SEARCH=1
# OPENAI_SEARCH_MODEL=gpt-4o-mini-search-preview
ANTHROPIC_API_KEY=
# Optional: Anthropic model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional: enable web search so Anthropic responses include live citations (Messages API + web_search tool).
# ANTHROPIC_USE_WEB_SEARCH=1
PERPLEXITY_API_KEY=
# Optional: Perplexity model (default: sonar). Use sonar-pro for higher quality and more citations.
# PERPLEXITY_MODEL=sonar
GOOGLE_API_KEY=
# Optional: Gemini model with Google Search grounding for citations (default: gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# Domains to track for citations (comma-separated)
TRACKED_DOMAINS=example.com,www.example.com

# API server (backend)
API_BASE_URL=http://localhost:8000

# Frontend: API base URL for browser requests. Required when the API is on a different host than the frontend.
# Add to frontend .env (or build env) and rebuild. Same as API_BASE_URL if you use one server; use full URL if API is elsewhere (e.g. https://api.truseo.io).
# VITE_API_URL=http://localhost:8000
# VITE_API_URL=https://api.truseo.io

# Trial (unauthenticated try-it flow): prompts count and delay between LLM calls
# TRIAL_PROMPTS_COUNT=5
# TRIAL_DELAY_SECONDS=5

# Trial abuse protection: rate limit per IP (default 1 request per 30 min)
# TRIAL_RATE_LIMIT_PER_IP=1
# TRIAL_RATE_LIMIT_WINDOW_MINUTES=30
# Queue backpressure: reject new trials when queue or concurrent runs exceed limit
# TRIAL_MAX_QUEUE_PENDING=80
# TRIAL_MAX_CONCURRENT_RUNS=15
# Cloudflare Turnstile CAPTCHA (optional): get keys at dashboard.cloudflare.com
TURNSTILE_SECRET_KEY=0x4AAAAAACrGsMLPkLAct6WLbNsoaNMIbLU     # backend: required for CAPTCHA verification when set
# Frontend: set VITE_TURNSTILE_SITE_KEY in .env (or build env) to show the widget

# LLM task queue worker: delay in seconds between processing consecutive tasks (default 5)
# QUEUE_DELAY_SECONDS=5

# Self-learning uplift: window (days) before/after draft publication to find monitoring runs for citation and brand uplift
# UPLIFT_BEFORE_DAYS=30
# UPLIFT_AFTER_DAYS=14

# Auth: JWT secret for signup/signin (required in production)
JWT_SECRET=change-me-in-production
# Optional: token expiry in seconds (default 604800 = 7 days)
# JWT_EXPIRE_SECONDS=604800

# Public URL of this API (for rewriting image URLs in published content so Hashnode/CMS can load images). If unset, API_BASE_URL is used. Production: https://truseo.io
# PUBLIC_URL=https://truseo.io

# Optional: S3 for generated images. When set, images are uploaded to S3 and S3 URLs are used in blogs.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
# AWS_REGION=us-east-1

# Optional: CMS for publishing (Sprint 3). Post URL is saved to draft after publish.
# WORDPRESS_URL=
# WORDPRESS_APP_PASSWORD=
# WEBFLOW_API_TOKEN=
# Ghost: site URL + Admin API key from Ghost Admin → Settings → Integrations
# GHOST_URL=           # e.g. https://your-site.com
# GHOST_ADMIN_API_KEY=
# Hashnode: token at hashnode.com/settings/developer
# HASHNODE_API_KEY=
# HASHNODE_PUBLICATION_ID=
# Dev.to: API key from dev.to/settings/extensions
# DEVTO_API_KEY=
# LinkedIn: OAuth access token + author URN (urn:li:person:ID or urn:li:organization:ID)
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_AUTHOR_URN=
# Notion: integration token + parent page/database ID (create pages under this)
# NOTION_INTEGRATION_TOKEN=
# NOTION_PARENT_ID=

# Optional: Distribution (Sprint 4)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=
